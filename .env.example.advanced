# Advanced configuration -- common overrides and illustrative examples.
# Some entries below show the in-code default (uncomment only to
# override); others are placeholder examples for opt-in settings that
# have no meaningful default (multi-repo `REPOS`, the verify gate,
# event / analytics sinks). The orchestrator runs fine when none of
# these are set. The full reference -- every knob, every default --
# lives in `docs/configuration.md`.

# --- Target repository ---

# REPO and TARGET_REPO_ROOT live in `.env.example` -- they are the
# basic knobs needed to point the orchestrator at any repo.

# Base branch in the target repo (PR base).
# BASE_BRANCH=main

# Name of the git remote in TARGET_REPO_ROOT that points at REPO.
# REMOTE_NAME=origin

# Multi-repo mode. One entry per `;` separator, each
# `owner/name|target_root|base_branch[|remote_name[|parallel_limit]]`.
# Overrides REPO / TARGET_REPO_ROOT / BASE_BRANCH / REMOTE_NAME when set.
# REPOS=owner1/repo1|/path/to/repo1|main;owner2/repo2|/path/to/repo2|master|private|2

# Where per-issue git worktrees are created.
# WORKTREES_DIR=../wt-orchestrator

# Base branch of the orchestrator's own repo (self-update path only).
# ORCHESTRATOR_BASE_BRANCH=main

# --- Agent CLIs ---

# Path to the codex / claude binaries. Override only if not on $PATH.
# CODEX_BIN=codex
# CLAUDE_BIN=claude

# git identity injected into every agent commit.
# AGENT_GIT_NAME=agent-orchestrator
# AGENT_GIT_EMAIL=agent-orchestrator@users.noreply.github.com

# Example DEV_AGENT spec with backend-CLI args (quoting follows shell rules):
# DEV_AGENT=codex -m gpt-5.5 -c 'model_reasoning_effort="xhigh"'

# --- Cadence and budgets ---

# Polling interval for the main loop, seconds.
# POLL_INTERVAL=60

# How many ticks apart the closed-issue recovery sweep runs. That sweep
# issues one closed-issue query per non-terminal workflow label PER REPO
# every tick; across many repos at a short POLL_INTERVAL it dominates
# request volume and exhausts GitHub's 5000 req/hour primary rate limit
# (symptom: repeated "403: Forbidden" + long "Setting next backoff to …s"
# stalls in orchestrator.log). 1 (default) runs it every tick; raise it
# (e.g. 4-5) on multi-repo hosts. Cost: an externally-merged/closed issue
# may take up to N-1 extra ticks to finalize to `done`. See
# docs/configuration.md#github-rate-limits.
# CLOSED_ISSUE_SWEEP_EVERY_N_TICKS=1

# Wall-clock cap per agent invocation, seconds.
# AGENT_TIMEOUT=1800

# Wall-clock cap per reviewer invocation. Defaults to AGENT_TIMEOUT.
# REVIEW_TIMEOUT=1800

# Review/fix iterations before parking on awaiting_human.
# MAX_REVIEW_ROUNDS=3

# Auto-conflict-resolution rounds before parking on awaiting_human.
# MAX_CONFLICT_ROUNDS=3

# Fresh implementer spawns per issue per 24h window (0 = unbounded).
# MAX_RETRIES_PER_DAY=3

# Resumes of one dev session before it is retired and respawned fresh from
# durable state, so a growing transcript cannot creep into a "Prompt is too
# long" context overflow (0 = resume forever).
# DEV_SESSION_MAX_RESUMES=10

# --- Parallelism ---

# Per-repo cap on concurrent in-flight issues per tick. Must be >= 1.
# MAX_PARALLEL_ISSUES_PER_REPO=1

# Global cap across all configured repos. Must be >= 1.
# MAX_PARALLEL_ISSUES_GLOBAL=3

# --- Stage toggles ---

# Kill switch for the `decomposing` stage. Truthy: 1, true, on, yes.
# DECOMPOSE=on

# Quiet window after the most recent PR/issue comment before resuming
# the dev session in `fixing`, seconds.
# IN_REVIEW_DEBOUNCE_SECONDS=600

# --- Local verify gate ---

# Ordered shell commands run in the per-issue worktree on
# VERDICT: APPROVED, before relabeling to `in_review`. Separate entries
# with `;`. Empty (default) skips the verify gate. Do NOT embed secret
# literals -- failures publish the command verbatim on the issue.
# VERIFY_COMMANDS=python3 -m pytest -q;ruff check .

# Per-command wall-clock cap for VERIFY_COMMANDS, seconds.
# VERIFY_TIMEOUT=600

# --- Observability ---

# Optional JSONL audit-event sink. One event per line; no built-in
# rotation -- pair with logrotate if you leave the orchestrator running.
# EVENT_LOG_PATH=/var/log/orchestrator/events.jsonl

# Project-local analytics JSONL sink. Defaults to LOG_DIR/analytics.jsonl.
# Set to empty / off / disabled / none to disable writes.
# ANALYTICS_LOG_PATH=

# Retention window for ANALYTICS_LOG_PATH, days (0 or negative = keep
# indefinitely).
# ANALYTICS_RETENTION_DAYS=90

# libpq URL for the analytics Postgres service in `analytics-db/`.
# Consumed by `python -m orchestrator.analytics.sync` and the Streamlit
# dashboard; NOT read by the polling loop.
# ANALYTICS_DB_URL=postgresql://orchestrator:orchestrator@127.0.0.1:5432/orchestrator_analytics

# Skill-trigger tracking. Set to 1 / true / on / yes to fold each agent's
# triggered skills (skills_triggered / skills_triggered_count /
# skills_available) into the agent_exit analytics record. Default off so
# records stay shape-compatible with installs that never opted in.
# TRACK_SKILL_TRIGGERS=on

# Dashboard parallel read fan-out. Set to 1 / true / on / yes to
# dispatch the dashboard's 13 widget reads across a ThreadPoolExecutor
# instead of issuing them sequentially. Each worker gets its own
# thread-local psycopg connection. Default off so an operator can A/B
# against the sequential baseline.
# DASHBOARD_PARALLEL_READS=on
