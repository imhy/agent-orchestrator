# GITHUB_TOKEN is intentionally NOT loaded from this file. The implementer
# agent runs in a sibling worktree with sandbox bypass and can read anything
# under REPO_ROOT, so a PAT here would be recoverable via a prompt injection.
#
# Provide the token via one of:
#   * Export GITHUB_TOKEN in the orchestrator's launch environment, or
#   * Write it to ~/.config/geserdugarov/agent-orchestrator/token (chmod 600;
#     path is derived from REPO).
# Override the file path with ORCHESTRATOR_TOKEN_FILE if you want a different
# location -- pick a path the agent worktree cannot reach via known relatives.
#
# Fine-grained PAT scopes: read/write on Contents, Issues, Pull requests,
# Metadata. Add Checks: Read if you plan to enable AUTO_MERGE -- without it,
# Actions-only PRs report check_state='none' and park indefinitely waiting
# for a human, even when CI is green. Create the PAT at
# https://github.com/settings/personal-access-tokens

# owner/name of the repo the orchestrator is responsible for. Used as the
# legacy single-repo configuration; when REPOS is set (see below) this and
# the matching TARGET_REPO_ROOT / BASE_BRANCH are ignored.
REPO=geserdugarov/agent-orchestrator

# Path to the local clone of REPO. Worktrees are `git worktree add`-ed from
# here, so commits land on this clone's history. Defaults to REPO_ROOT (the
# orchestrator's own checkout) for the self-bootstrap case. Set this when the
# orchestrator code lives in one clone but drives PRs into a different repo.
# TARGET_REPO_ROOT=/path/to/target/clone

# Base branch in the *target* repo. Used for both the worktree base and the
# PR base. Default `main`; set to whatever the target's default branch is
# (e.g. `master`).
# BASE_BRANCH=main

# Name of the git remote in TARGET_REPO_ROOT that points at REPO on GitHub.
# Defaults to `origin`. Override when the local clone tracks several remotes
# (e.g. a public `origin` and a private fork named `private`) and the
# orchestrator should drive the non-default one. Ignored when REPOS is set --
# put the remote name in the per-entry fourth field there instead.
# REMOTE_NAME=origin

# Multi-repo configuration. Each entry is `owner/name|target_root|base_branch`
# with an OPTIONAL fourth `|remote_name` field (defaults to `origin` when
# omitted), separated by a newline OR a `;` (the .env loader cannot represent
# newlines inside a value, so use `;` here and prefer newlines when exporting
# in a shell).
#
# When REPOS is set the legacy REPO/TARGET_REPO_ROOT/BASE_BRANCH/REMOTE_NAME
# quartet is ignored and the orchestrator polls every entry on each tick.
# Worktrees live under `WORKTREES_DIR/<owner>__<name>/issue-N` so two repos
# with the same issue number cannot collide.
#
# Each repo needs its own GitHub token at `~/.config/<owner>/<repo>/token`
# (or set GITHUB_TOKEN once in the environment if a single PAT has access to
# every listed repo). Validation happens at import: malformed entries, empty
# owner/name or base_branch, and duplicate slugs all abort startup.
# REPOS=owner1/repo1|/path/to/repo1|main;owner2/repo2|/path/to/repo2|master|private

# Where per-issue git worktrees are created. The orchestrator namespaces each
# worktree by repo slug (so two repos with the same issue number cannot share
# a checkout), giving the on-disk layout `WORKTREES_DIR/<owner>__<name>/issue-N`
# (and `decompose-N` for the read-only decomposer scratch).
# WORKTREES_DIR=../wt-orchestrator

# Base branch of the orchestrator's *own* repo (REPO_ROOT). Used only by the
# self-update path: run.sh fast-forwards to it on every restart, and
# `_self_modifying_merge_happened` watches `origin/<this>` for new commits
# that touch `orchestrator/`. Decoupled from BASE_BRANCH so the target repo
# can have a different default branch without breaking self-update.
# ORCHESTRATOR_BASE_BRANCH=main

# Polling interval for the main loop, seconds.
POLL_INTERVAL=60

# Hard wall-clock cap per agent invocation, seconds.
AGENT_TIMEOUT=1800

# Hard wall-clock cap for the codex review pass, seconds. Defaults to AGENT_TIMEOUT.
REVIEW_TIMEOUT=1800

# How many review/fix iterations to attempt before parking on awaiting_human.
MAX_REVIEW_ROUNDS=10

# How many auto-conflict-resolution rounds `_handle_resolving_conflict` runs
# before parking awaiting_human. Each round merges origin/<BASE_BRANCH> into
# the per-issue branch and resumes the dev agent on remaining conflicts.
MAX_CONFLICT_ROUNDS=10

# Cap on how many fresh implementing-codex spawns one issue can consume within
# a 24h window opened at the first counted attempt; the window resets once 24h
# has elapsed. Resumes on human reply do NOT count against the budget.
# 0 means unbounded.
MAX_RETRIES_PER_DAY=10

# Comma-separated GitHub logins the orchestrator @-mentions when it needs human attention.
HITL_HANDLE=github-user

# Comma-separated GitHub logins whose unlabeled issues the orchestrator is
# allowed to auto-pick-up. Empty (default) disables the allowlist and
# preserves the legacy "anyone can trigger" behavior. Set this on a public
# repo so random users can't spend agent compute on useless tasks. The guard
# only applies at pickup; if a maintainer hand-labels an outsider's issue
# (e.g. `implementing`), the workflow still drives it to completion.
# ALLOWED_ISSUE_AUTHORS=github-user,agent-orchestrator

# Which backend implements vs. reviews vs. decomposes. Each value is a
# shell-like command spec: the FIRST TOKEN names the backend and must
# match `codex` or `claude` case-insensitively (`CODEX`, `Claude`, and
# `codex` all parse to the same backend; the lowercased form is used
# only for dispatch in agents.py -- pinned state stores the raw spec
# verbatim, so `DEV_AGENT=CODEX -m gpt-5.5` is persisted as the literal
# `CODEX -m gpt-5.5` and the lowercase happens again every resume when
# `_parse_agent_spec` re-parses it). Anything else aborts at startup
# so a typo cannot silently fall back.
#
# Any remaining tokens are forwarded verbatim as backend-CLI args on
# every spawn for that role -- typically model and reasoning-effort
# selection. Quoting follows shell rules (parsed with `shlex.split`).
#
# Examples:
#   DEV_AGENT=claude
#   DEV_AGENT=claude --model claude-opus-4-7
#   DEV_AGENT=claude --model claude-opus-4-7 --effort high
#   DEV_AGENT=codex -m gpt-5.5 -c 'model_reasoning_effort="xhigh"'
#   REVIEW_AGENT=codex -m gpt-5.5-codex
#   REVIEW_AGENT=codex -m gpt-5.5-codex -c 'model_reasoning_effort="high"'
#   REVIEW_AGENT=claude --model claude-sonnet-4-6 --effort high
#   DECOMPOSE_AGENT=claude --model claude-opus-4-7 --effort medium
#
# Interaction with CODEX_BIN / CLAUDE_BIN: the first token is only a
# backend selector (it picks the codex vs. claude runner in agents.py).
# The actual executable launched is `CODEX_BIN` when the first token is
# `codex` and `CLAUDE_BIN` when it is `claude`, so set those to a full
# path when the CLI is not on `$PATH`. Writing the full path as the first
# token (e.g. `DEV_AGENT=/usr/local/bin/codex ...`) is rejected.
#
# In-flight issues keep using the pinned full spec until the agent
# session ends: the spec the spawn ran with (backend AND args) is
# persisted to the issue's pinned state (`dev_agent` /
# `decomposer_agent`) before the spawn, and `_handle_*` re-parses that
# stored spec on every resume. Flipping `DEV_AGENT` / `DECOMPOSE_AGENT`
# in env therefore only affects fresh issues; any issue with a live
# session keeps the original backend + args until it reaches a terminal
# label (`done` / `rejected`).
#
# The reviewer is spawned fresh every round, so `REVIEW_AGENT` changes
# take effect on the next round; the most recent value is recorded in
# `review_agent` for traceability. DECOMPOSE_AGENT is validated at
# import even when DECOMPOSE=off, so toggling DECOMPOSE back on never
# surfaces a fresh "that env var was always invalid" failure.
DEV_AGENT=claude
REVIEW_AGENT=codex
DECOMPOSE_AGENT=claude

# Path to the codex CLI binary -- the executable launched when a role's
# first token is `codex`. Override only if not on $PATH.
CODEX_BIN=codex

# Path to the claude CLI binary -- the executable launched when a role's
# first token is `claude`. Override only if not on $PATH.
CLAUDE_BIN=claude

# git identity injected into each codex spawn via GIT_AUTHOR_*/GIT_COMMITTER_*
# env vars, so agent commits are attributable to the orchestrator rather than
# the host's git config. The default email uses GitHub's noreply form so it
# won't bounce and won't link to any real user account.
# AGENT_GIT_NAME=agent-orchestrator
# AGENT_GIT_EMAIL=agent-orchestrator@users.noreply.github.com

# Allow the orchestrator to merge approved + mergeable + green-CI PRs out of
# `in_review`, transitioning the issue to `done` and closing it. Default off
# so existing setups keep the manual-merge contract; flip to `on` once the
# loop is dogfooded. Truthy spellings: 1, true, on, yes.
# AUTO_MERGE=off

# Quiet window (seconds) after the most recent PR/issue comment in `in_review`
# before resuming the dev session on the comment. Matches the 10-minute
# debounce documented in docs/workflow.md. Lower values risk firing while a
# human is still typing; higher values delay reaction to PR feedback.
# IN_REVIEW_DEBOUNCE_SECONDS=600

# Kill switch for the `decomposing` stage. on (default) routes new unlabeled
# issues through `_handle_decomposing` which asks DECOMPOSE_AGENT for a
# fenced `orchestrator-manifest` JSON block (decision: single | split). off
# reverts to the legacy direct-to-`implementing` pickup -- useful as a
# rollout safety valve if manifest output proves unreliable.
#
# The flag also applies mid-flight: if an issue was already labeled
# `decomposing` (or parked there awaiting a human) when the orchestrator
# restarts with the flag off, the next tick routes it to `implementing` too
# instead of resuming the decomposer. Half-finished splits already on GitHub
# still finalize to `blocked` -- the kill switch must not strand orphan
# child issues.
#
# Truthy spellings: 1, true, on, yes; anything else (including typos)
# disables it.
# DECOMPOSE=on

# Optional JSONL event sink. When set, the orchestrator appends one JSON
# object per audit event -- `{ts, repo, issue, event, stage, ...}`, UTC
# timestamps at second precision, keys sorted -- to the path below.
#
# Today's events:
#   * `stage_enter`         - workflow label transition (from set_workflow_label)
#   * `agent_spawn`/`agent_exit` - bookend every decomposer / implementer /
#     reviewer / resume / conflict-resolution agent invocation; both carry
#     `agent`, `agent_role`, plus `review_round` / `retry_count` when
#     present. On `agent_spawn`, `session_id` is the resume session id and
#     is OMITTED for fresh spawns (None values are dropped by
#     `build_event_record`). On `agent_exit`, `session_id` is the result
#     session id; `agent_exit` additionally carries `duration_s`,
#     `exit_code`, and `timed_out`
#   * `review_verdict`      - reviewer's `approved` / `changes_requested` /
#     `unknown` after `_handle_validating` parses the agent's final message
#   * `park_awaiting_human` - every park call site, with the current stage
#     and a short `reason` (`agent_timeout`, `push_failed`, `failed_checks`,
#     `agent_question`, `agent_silent`, `dirty_worktree`, `reviewer_*`, ...)
#   * `pr_opened`           - implementer pushed the branch and opened the PR
#   * `pr_merged`           - PR merged (external manual merge OR AUTO_MERGE);
#     `merge_method` is `"external"` or `"squash"`
#   * `pr_closed_without_merge` - PR closed unmerged from in_review or
#     resolving_conflict (issue moves to `rejected`)
#   * `merge_attempt`       - AUTO_MERGE `gh.merge_pr` call OR a
#     `git merge origin/<base>` inside `_handle_resolving_conflict`;
#     carries `method` (`"squash"` or `"base_merge"`) and `result`
#     (`"success"` / `"failed"` / `"conflict"`)
#   * `conflict_round`      - entered `resolving_conflict` (`action="entered"`)
#     or incremented the per-PR counter (`action="incremented"`, with `outcome`)
#
# Tail this file to follow the workflow without scraping logs. Unset
# (the default) keeps the legacy behavior: no file is opened. Synchronous
# append; create the parent directory if it does not exist. No built-in
# rotation -- pair with `logrotate` (or your platform's equivalent) if you
# leave the orchestrator running for long enough that file size matters.
#
# Precedence: the pinned JSON state comment on each issue remains the
# authoritative per-issue state. The event log is append-only and exists
# for audit / observability only; if it disagrees with pinned state (e.g.
# a write to disk failed and was logged-and-swallowed, the file was
# truncated by rotation, or events were lost to a disk-full window),
# trust pinned state and treat the log as a lossy tail.
# EVENT_LOG_PATH=/var/log/orchestrator/events.jsonl
