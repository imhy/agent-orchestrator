# GITHUB_TOKEN is NOT loaded from this file -- the implementer agent
# could read .env via sandbox bypass. Export it before launch, or write
# it to ~/.config/<owner>/<repo>/token (chmod 600). Fine-grained PAT
# scopes and the security rationale are in `docs/configuration.md`.

# owner/name of the GitHub repo the orchestrator drives. Leave as-is to
# manage this orchestrator's own repo (self-bootstrap); set to any other
# `owner/name` (e.g. `lance-open-source/lance`) plus TARGET_REPO_ROOT
# below to drive a different repo without touching the rest of this file.
REPO=geserdugarov/agent-orchestrator

# Path to the local clone of REPO. Worktrees are `git worktree add`-ed
# from here. Defaults to the orchestrator's own checkout (self-bootstrap);
# set this when REPO points at a different repo.
# TARGET_REPO_ROOT=/path/to/target/clone

# Comma-separated GitHub logins the orchestrator @-mentions when it
# needs human attention.
HITL_HANDLE=github-user

# Comma-separated GitHub logins whose unlabeled issues the orchestrator
# may auto-pick-up. Empty (the default) allows any author --
# WARNING: on a public repo this lets random users spend the
# orchestrator's compute budget on arbitrary tasks. Set this to your own
# logins on any public repo you point the orchestrator at.
# ALLOWED_ISSUE_AUTHORS=github-user,agent-orchestrator

# Backend for each agent role: `codex` or `claude` (optionally followed
# by backend-CLI args). Only the backends you route to need to be
# authenticated on the host. Full spec format: `docs/workflow.md`.
DEV_AGENT=claude
REVIEW_AGENT=codex
DECOMPOSE_AGENT=claude

# Advanced knobs (multi-repo, parallelism, local verify gate,
# analytics, observability) live in `.env.example.advanced` and are
# fully documented in `docs/configuration.md`.
