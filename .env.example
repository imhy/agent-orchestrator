# GITHUB_TOKEN is NOT loaded from this file -- the implementer agent
# could read .env via sandbox bypass. Export it before launch, or write
# it to ~/.config/<owner>/<repo>/token (chmod 600). Fine-grained PAT
# scopes and the security rationale are in `docs/configuration.md`.

# owner/name of the GitHub repo the orchestrator drives.
REPO=geserdugarov/agent-orchestrator

# Comma-separated GitHub logins the orchestrator @-mentions when it
# needs human attention.
HITL_HANDLE=github-user

# Backend for each agent role: `codex` or `claude` (optionally followed
# by backend-CLI args). Only the backends you route to need to be
# authenticated on the host. Full spec format: `docs/workflow.md`.
DEV_AGENT=claude
REVIEW_AGENT=codex
DECOMPOSE_AGENT=claude

# Advanced knobs (multi-repo, parallelism, auto-merge, local verify
# gate, analytics, observability) live in `.env.example.advanced` and
# are fully documented in `docs/configuration.md`.
